#!/usr/bin/env bash
# hyve-update-check — check if a newer hyve version is available
#
# Output (stdout, one line):
#   UPGRADE_AVAILABLE <old> <new>   — new version exists
#   JUST_UPGRADED <old> <new>       — upgrade just completed
#   (empty)                         — up to date, or check disabled/snoozed
#
# Cache: ~/.hyve/last-update-check (60 min TTL for up-to-date, 720 min for available)
# Snooze: ~/.hyve/update-snoozed (escalating backoff: 24h → 48h → 7d)
#
# Env overrides:
#   HYVE_STATE_DIR       — override ~/.hyve
#   HYVE_REMOTE_URL      — override VERSION fetch URL
#   HYVE_UPDATE_FORCE=1  — bypass cache and snooze
set -euo pipefail

HYVE_DIR="$(cd "$(dirname "$0")/.." && pwd)"
STATE_DIR="${HYVE_STATE_DIR:-$HOME/.hyve}"
CACHE_FILE="$STATE_DIR/last-update-check"
SNOOZE_FILE="$STATE_DIR/update-snoozed"
UPGRADED_FILE="$STATE_DIR/just-upgraded-from"
REMOTE_URL="${HYVE_REMOTE_URL:-https://raw.githubusercontent.com/pototostudio/hyve/main/VERSION}"

mkdir -p "$STATE_DIR"

LOCAL_VERSION=$(cat "$HYVE_DIR/VERSION" 2>/dev/null | tr -d '[:space:]' || echo "unknown")

# --- Check for just-upgraded marker ---
if [ -f "$UPGRADED_FILE" ]; then
  OLD=$(cat "$UPGRADED_FILE" 2>/dev/null | tr -d '[:space:]')
  rm -f "$UPGRADED_FILE"
  echo "JUST_UPGRADED $OLD $LOCAL_VERSION"
  exit 0
fi

# --- Check if update checking is disabled ---
CHECK_ENABLED=$("$HYVE_DIR/bin/hyve-config" get update_check 2>/dev/null || echo "true")
if [ "$CHECK_ENABLED" = "false" ] && [ "${HYVE_UPDATE_FORCE:-}" != "1" ]; then
  exit 0
fi

# --- Helper: current epoch ---
now() { date +%s 2>/dev/null || python3 -c 'import time; print(int(time.time()))'; }
NOW=$(now)

# --- Check snooze (unless forced) ---
if [ -f "$SNOOZE_FILE" ] && [ "${HYVE_UPDATE_FORCE:-}" != "1" ]; then
  SNOOZE_VERSION=$(awk '{print $1}' "$SNOOZE_FILE" 2>/dev/null || true)
  SNOOZE_LEVEL=$(awk '{print $2}' "$SNOOZE_FILE" 2>/dev/null || echo "1")
  SNOOZE_EPOCH=$(awk '{print $3}' "$SNOOZE_FILE" 2>/dev/null || echo "0")

  # Snooze duration by level: 1=24h, 2=48h, 3+=7d
  case "$SNOOZE_LEVEL" in
    1) SNOOZE_SECS=86400 ;;
    2) SNOOZE_SECS=172800 ;;
    *) SNOOZE_SECS=604800 ;;
  esac

  SNOOZE_EXPIRES=$((SNOOZE_EPOCH + SNOOZE_SECS))
  if [ "$NOW" -lt "$SNOOZE_EXPIRES" ]; then
    exit 0  # Still snoozed
  fi
fi

# --- Fast path: check cache ---
if [ -f "$CACHE_FILE" ] && [ "${HYVE_UPDATE_FORCE:-}" != "1" ]; then
  CACHE_STATUS=$(awk '{print $1}' "$CACHE_FILE" 2>/dev/null || true)
  CACHE_EPOCH=$(awk '{print $NF}' "$CACHE_FILE" 2>/dev/null || echo "0")

  # TTL: 60 min for UP_TO_DATE, 720 min for UPGRADE_AVAILABLE
  case "$CACHE_STATUS" in
    UP_TO_DATE)       TTL=3600 ;;
    UPGRADE_AVAILABLE) TTL=43200 ;;
    *)                TTL=0 ;;
  esac

  CACHE_EXPIRES=$((CACHE_EPOCH + TTL))
  if [ "$NOW" -lt "$CACHE_EXPIRES" ]; then
    # Cache is fresh — emit if upgrade available
    if [ "$CACHE_STATUS" = "UPGRADE_AVAILABLE" ]; then
      OLD=$(awk '{print $2}' "$CACHE_FILE" 2>/dev/null || true)
      NEW=$(awk '{print $3}' "$CACHE_FILE" 2>/dev/null || true)
      echo "UPGRADE_AVAILABLE $OLD $NEW"
    fi
    exit 0
  fi
fi

# --- Slow path: fetch remote VERSION ---
REMOTE_VERSION=$(curl -sf --max-time 5 "$REMOTE_URL" 2>/dev/null | tr -d '[:space:]' || true)

# Validate version format (digits and dots only)
if [ -z "$REMOTE_VERSION" ] || ! echo "$REMOTE_VERSION" | grep -qE '^[0-9]+\.[0-9.]+$'; then
  # Bad response — don't cache, don't nag
  exit 0
fi

if [ "$LOCAL_VERSION" = "$REMOTE_VERSION" ]; then
  echo "UP_TO_DATE $LOCAL_VERSION $NOW" > "$CACHE_FILE"
  exit 0
else
  echo "UPGRADE_AVAILABLE $LOCAL_VERSION $REMOTE_VERSION $NOW" > "$CACHE_FILE"
  # New version resets snooze
  if [ -f "$SNOOZE_FILE" ]; then
    SNOOZED_FOR=$(awk '{print $1}' "$SNOOZE_FILE" 2>/dev/null || true)
    if [ "$SNOOZED_FOR" != "$REMOTE_VERSION" ]; then
      rm -f "$SNOOZE_FILE"
    fi
  fi
  echo "UPGRADE_AVAILABLE $LOCAL_VERSION $REMOTE_VERSION"
  exit 0
fi
